# generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# your app's public url (e.g. https://hivesync.vercel.app)
# for local dev: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# your google email — only this account can sign in.
# prevents anyone from claiming the deployment before you do.
# set this before your first deploy.
ALLOWED_GOOGLE_EMAIL=

# secret for /api/sync/poll — generate with: openssl rand -base64 32
CRON_SECRET=

# encryption key for oauth tokens stored in the database
# must be exactly 32 bytes — generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# foursquare developer app credentials
# create at: https://foursquare.com/developers/apps
FOURSQUARE_CLIENT_ID=
FOURSQUARE_CLIENT_SECRET=

# google cloud oauth credentials
# create at: https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# database
# vercel neon sets these automatically — copy DATABASE_URL_UNPOOLED into DIRECT_URL
# for local dev: leave blank to use sqlite (file:./prisma/dev.db)
DATABASE_URL=
DIRECT_URL=

# optional — enables enriched addresses and google maps links on events
GOOGLE_MAPS_API_KEY=

# optional — app-level safety caps for google places enrichment
GOOGLE_PLACES_DAILY_LIMIT=25
GOOGLE_PLACES_MONTHLY_LIMIT=500
GOOGLE_PLACES_BACKFILL_RUN_LIMIT=250
GOOGLE_PLACES_WARNING_THRESHOLD=0.8
