generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model UserConfig {
  id                   Int      @id @default(autoincrement())
  foursquareToken      String?
  foursquareUserId     String?
  foursquareDisplayName String?
  foursquarePhotoUrl   String?
  googleCredentialsJson String?
  googleEmail          String?
  googlePhotoUrl       String?
  ogMode               Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("user_config")
}

model SyncedCheckin {
  checkinId        String   @id
  calendarEventId  String
  calendarEventUrl String?
  venueId          String?
  venueName        String?
  venueCity        String?
  venueCategory    String?
  checkinTimestamp Int?
  isMayor          Boolean  @default(false)
  description      String?
  stickerImageUrl  String?
  syncedAt         DateTime @default(now())

  @@map("synced_checkins")
}

model VenueEnrichment {
  foursquareVenueId      String   @id
  foursquareName         String?
  foursquareAddress      String?
  foursquareCity         String?
  foursquareState        String?
  foursquareCountry      String?
  foursquarePostalCode   String?
  foursquareLatitude     Float?
  foursquareLongitude    Float?
  googlePlaceId          String?
  googleMapsUri          String?
  googleFormattedAddress String?
  googleLookupStatus     String   @default("PENDING")
  googleError            String?
  googleFetchedAt        DateTime?
  cacheHits              Int      @default(0)
  lastCacheHitAt         DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("venue_enrichments")
}

model GooglePlacesUsage {
  date      String   @id
  calls     Int      @default(0)
  cacheHits Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("google_places_usage")
}

model GooglePlacesSettings {
  id                Int      @id
  dailyLimit        Int?
  monthlyLimit      Int?
  backfillRunLimit  Int?
  warningThreshold  Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("google_places_settings")
}

model SyncCountAudit {
  id                  Int      @id
  firstYear           Int
  lastYear            Int
  checkedYears        Json
  totalCheckins       Int?
  totalSynced         Int
  foundInCheckedYears Int      @default(0)
  unaccountedCheckins Int?
  completed           Boolean  @default(false)
  checkedAt           DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("sync_count_audits")
}

model SyncLog {
  id           String   @id @default(uuid())
  type         SyncType
  synced       Int      @default(0)
  skipped      Int      @default(0)
  errors       Int      @default(0)
  errorMessage String?
  fromDate     String?
  toDate       String?
  createdAt    DateTime @default(now())

  @@map("sync_logs")
}

model SyncJob {
  id             String    @id @default(uuid())
  status         JobStatus @default(PENDING)
  afterTimestamp  Int?
  beforeTimestamp Int?
  currentOffset   Int       @default(0)
  totalSynced    Int       @default(0)
  totalSkipped   Int       @default(0)
  totalErrors    Int       @default(0)
  googlePlacesCalls Int      @default(0)
  googlePlacesRunLimit Int?
  googlePlacesApproved Boolean @default(false)
  googlePlacesAllowFallback Boolean @default(true)
  jobType        String?
  rangeCheckins   Json?
  errorMessage   String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  @@map("sync_jobs")
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum SyncType {
  FULL
  QUICK
  POLL
  RANGE
  DELETE
  RESYNC
  CLEAR
}
